---
import Layout from "../layouts/Layout.astro";
import LaunchVisualizer from "../islands/LaunchVisualizer.svelte";
import PodComparison from "../islands/PodComparison.svelte";
import TubeCrossSection from "../islands/TubeCrossSection.svelte";
import { RAIL, GRYPHON, KEPLER, COSTS, MISSION } from "../data/launch";
---
<Layout>
  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo">
        <span class="logo-mark">⚡</span>
        <span class="logo-text">BGKPJR</span>
        <span class="logo-sub">Launch Architecture</span>
      </div>
      <nav class="nav">
        <a href="#visualizer">Visualizer</a>
        <a href="#systems">Systems</a>
        <a href="#pods">Cargo Pods</a>
        <a href="#math">Physics</a>
        <a href="https://github.com/thebardchat/BGKPJR-Core-Simulations" target="_blank" rel="noopener">Core Sim →</a>
      </nav>
    </div>
  </header>

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero blueprint-grid">
    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <span class="badge badge-cyan">Pre-Phase A Concept</span>
        <span class="badge badge-amber">EM Launch Architecture</span>
        <span class="badge badge-lime">90% Cost Reduction Target</span>
      </div>
      <h1 class="hero-title">
        Brazelton Gryphon Kepler<br/>
        <span class="accent-text">Propulsion Jump Revolution</span>
      </h1>
      <p class="hero-desc">
        A three-stage hybrid launch system that decouples acceleration from propulsion.
        Ground-based coilgun magnets in an evacuated tunnel provide the first {RAIL.exitVelocityMs.toLocaleString()} m/s
        (Mach {RAIL.exitMach}) — no first-stage propellant consumed, no booster to recover.
        A liquid-hydrogen cryogenic membrane seals the muzzle. Gryphon wings lift the rest.
        Kepler's solar sail carries it onward.
      </p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-val">{RAIL.lengthKm} km</div>
          <div class="stat-label">Maglev Rail</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">Mach {RAIL.exitMach}</div>
          <div class="stat-label">Exit Velocity</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">{KEPLER.sailAreaM2.toLocaleString()} m²</div>
          <div class="stat-label">Kepler Sail</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">${COSTS.bgkpjrMaturePerKg}/kg</div>
          <div class="stat-label">Target Cost</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── LAUNCH VISUALIZER ─────────────────────────────────────── -->
  <section class="section" id="visualizer">
    <div class="container">
      <div class="section-header">
        <div class="label">Interactive Simulation</div>
        <h2>Full Mission Sequence</h2>
        <p class="section-desc">
          Watch all four stages in real-time: maglev acceleration, Gryphon wing deploy and atmospheric
          climb, hybrid propulsion burn to orbit, and Kepler solar sail deployment. Use the controls
          to scrub through mission time or jump to any stage.
        </p>
      </div>
      <LaunchVisualizer client:only="svelte" />
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── THREE STAGES ─────────────────────────────────────────── -->
  <section class="section" id="systems">
    <div class="container">
      <div class="section-header">
        <div class="label">Architecture Overview</div>
        <h2>Three Stages, One Mission</h2>
      </div>
      <div class="stages-grid">

        <div class="stage-card">
          <div class="stage-num cyan">01</div>
          <h3>Maglev Rail — "Jump"</h3>
          <p>A {RAIL.lengthKm}-km evacuated coilgun tube at {RAIL.inclinationDeg}° incline accelerates the vehicle to Mach {RAIL.exitMach} in {RAIL.runTimeSec} seconds. Tube pressure is held at {RAIL.pressureAtm} atm to eliminate aerodynamic drag. Linear synchronous motor architecture: copper drive coils on the rail, REBCO superconducting armature on the vehicle (cooled to {RAIL.armatureTempK} K). Peak field {RAIL.magFieldT} T. Sustained at {RAIL.peakGForce} G — within human-rating margin.</p>
          <table class="stage-table">
            <tr><td>Rail length</td><td class="cyan">{RAIL.lengthKm} km</td></tr>
            <tr><td>Exit velocity</td><td class="cyan">Mach {RAIL.exitMach} ({RAIL.exitVelocityMs.toLocaleString()} m/s)</td></tr>
            <tr><td>Peak G-load</td><td class="cyan">{RAIL.peakGForce} G</td></tr>
            <tr><td>Tube pressure</td><td class="cyan">{RAIL.pressureAtm} atm</td></tr>
            <tr><td>Drive architecture</td><td class="cyan">LSM coilgun · {RAIL.coilCount.toLocaleString()} coils @ {RAIL.coilSpacingM} m</td></tr>
            <tr><td>Magnet field</td><td class="cyan">{RAIL.magFieldT} T (REBCO armature @ {RAIL.armatureTempK} K)</td></tr>
            <tr><td>Muzzle seal</td><td class="cyan">LH₂ cryogenic membrane</td></tr>
          </table>
          <a class="stage-deep-link" href="https://thebardchat.github.io/BGKPJR-Stage1-Tube" target="_blank" rel="noopener">Stage 1 Deep Dive →</a>
        </div>

        <div class="stage-card">
          <div class="stage-num amber">02</div>
          <h3>Gryphon — Atmospheric Ascent</h3>
          <p>At tube exit, Gryphon's variable-geometry wings deploy instantly. Aerodynamic lift extends the boost window from Mach {RAIL.exitMach} to Mach {GRYPHON.maxMach}, using the atmosphere as a propellant-free energy source. Hybrid propulsion then burns to orbital velocity. Gryphon glides back unpowered — no landing propellant, no recovery legs.</p>
          <table class="stage-table">
            <tr><td>Wingspan</td><td class="amber">{GRYPHON.wingspanM} m</td></tr>
            <tr><td>Dry mass</td><td class="amber">{GRYPHON.massDryKg.toLocaleString()} kg</td></tr>
            <tr><td>Payload</td><td class="amber">{GRYPHON.payloadKg.toLocaleString()} kg</td></tr>
            <tr><td>Max Mach</td><td class="amber">Mach {GRYPHON.maxMach}</td></tr>
            <tr><td>Glide ratio</td><td class="amber">{GRYPHON.glideRatio}:1</td></tr>
          </table>
        </div>

        <div class="stage-card">
          <div class="stage-num lime">03</div>
          <h3>Kepler Sail — Orbital & Beyond</h3>
          <p>Above {KEPLER.deployAltKm} km, a {KEPLER.sailAreaM2.toLocaleString()} m² {KEPLER.materialCP1} solar sail deploys from a {KEPLER.massKg} kg boom assembly. Zero propellant. Zero fuel mass fraction. Solar pressure at 1 AU provides a continuous {KEPLER.nominalDvMmps} mm/s² delta-v. The Kepler stage never runs out of propellant — it runs out of mission.</p>
          <table class="stage-table">
            <tr><td>Sail area</td><td class="lime">{KEPLER.sailAreaM2.toLocaleString()} m²</td></tr>
            <tr><td>Sail mass</td><td class="lime">{KEPLER.massKg} kg</td></tr>
            <tr><td>Material</td><td class="lime">{KEPLER.materialCP1}</td></tr>
            <tr><td>Deploy altitude</td><td class="lime">{KEPLER.deployAltKm} km</td></tr>
            <tr><td>Solar ΔV</td><td class="lime">{KEPLER.nominalDvMmps} mm/s²</td></tr>
          </table>
        </div>

      </div>
    </div>
  </section>


  <div class="divider container"></div>

  <!-- ── INSIDE THE LAUNCH TUBE ───────────────────────────────── -->
  <section class="section" id="tube">
    <div class="container">
      <div class="section-header">
        <div class="label">Stage 1 — Deep Dive</div>
        <h2>Inside the EM Launch Tube</h2>
        <p class="section-desc">
          The {RAIL.lengthKm} km barrel is the largest electromagnetic accelerator ever proposed.
          {RAIL.coilCount.toLocaleString()} copper drive coils at {RAIL.coilSpacingM} m spacing form a Linear Synchronous Motor:
          stationary coils on the tube, REBCO superconducting armature on the vehicle. The pod surfs a traveling
          magnetic wave from zero to Mach {RAIL.exitMach} in {RAIL.runTimeSec} seconds — then breaches a liquid-hydrogen
          cryogenic membrane that holds the vacuum behind it. The membrane breach is the engineered event
          that gates the entire architecture.
        </p>
      </div>

      <TubeCrossSection client:only="svelte" />

      <div class="tube-mech-grid">
        <div class="tube-card">
          <div class="tc-num">01</div>
          <h4>Sequential Coil Firing</h4>
          <p>Each copper drive coil along the {RAIL.lengthKm} km tube is energized individually, timed to the pod&apos;s exact position.
          Leading coils fire first, generating forward magnetic attraction. Trailing coils de-energize immediately
          to prevent back-pull. The result is a traveling magnetic wave that the vehicle&apos;s onboard REBCO armature
          continuously chases — Linear Synchronous Motor architecture, identical in principle to a maglev train scaled to launch energies.</p>
          <div class="tc-spec">{RAIL.coilCount.toLocaleString()} coils · {RAIL.coilSpacingM} m spacing · &lt;1 ms switching · {RAIL.magFieldT} T peak field</div>
        </div>
        <div class="tube-card">
          <div class="tc-num">02</div>
          <h4>The Vehicle Armature</h4>
          <p>The midsection of the vehicle carries a REBCO high-temperature superconducting armature ring,
          chilled to {RAIL.armatureTempK} K by an onboard cryostat that doubles as the LH₂ propellant tank.
          The armature couples magnetically to the tube&apos;s traveling field. No physical contact with the bore wall.
          No friction. No rail erosion. The vehicle rides a magnetic cushion at {RAIL.peakGForce} G for {RAIL.runTimeSec} seconds.</p>
          <div class="tc-spec">REBCO armature · {RAIL.armatureTempK} K LH₂ coolant · ~30 mm bore clearance</div>
        </div>
        <div class="tube-card">
          <div class="tc-num">03</div>
          <h4>{RAIL.energyGJ} GJ Energy Source</h4>
          <p>A single launch transfers ~{Math.round(0.5 * GRYPHON.massGrossFuelKg * RAIL.exitVelocityMs ** 2 / 1e9)} GJ of kinetic energy
          to a fully-loaded vehicle (mass {(GRYPHON.massGrossFuelKg/1000).toFixed(0)} t at {RAIL.exitVelocityMs.toLocaleString()} m/s).
          With drive efficiency ~60%, the SMES (Superconducting Magnetic Energy Storage) bank stores {RAIL.energyGJ} GJ.
          Peak discharge lasts {RAIL.runTimeSec} seconds. Charge rate: {RAIL.chargeRateMW} MW. Peak draw: {RAIL.peakPowerGW} GW.
          Rail Δv represents {(MISSION.railDvFraction * 100).toFixed(0)}% of the {MISSION.deltaVToLeoMs.toLocaleString()} m/s required to reach LEO — the rest is rocket propulsion.</p>
          <div class="tc-spec">Stored energy: {RAIL.energyGJ} GJ · Peak power: {RAIL.peakPowerGW} GW · Recharge: {RAIL.chargeTimeMin} min</div>
        </div>
      </div>

      <!-- ══ MUZZLE INTERFACE — VACUUMGATE LH₂ MEMBRANE ══ -->
      <div class="muzzle-section">
        <div class="muzzle-header">
          <div class="label" style="color:var(--amber)">The Critical Engineering Problem</div>
          <h3>The Muzzle Interface — Liquid Hydrogen Cryogenic Membrane</h3>
          <p>
            When a vehicle exits the tube at Mach {RAIL.exitMach} ({RAIL.exitVelocityMs.toLocaleString()} m/s), it transitions
            from {RAIL.pressureAtm} atm vacuum into ~1 atm atmosphere in milliseconds.
            Dynamic pressure at exit is {RAIL.muzzleStagnationMPa} MPa — without mitigation, the structural shock destroys the vehicle.
            The single problem this membrane solves is making that transition survivable, and turning the energy released into a thrust impulse.
          </p>
          <p style="margin-top:14px">
            <strong style="color:var(--amber)">The novel IP:</strong> a thin {RAIL.muzzleLh2TempK} K liquid-hydrogen membrane sealed behind a
            structural diaphragm. As the vehicle breaches it, the LH₂ vaporizes (~1000× volume expansion), mixes with atmospheric oxygen
            in the wake, and detonates. The detonation wave is engineered to propagate <em>behind</em> the vehicle, providing a controlled
            thrust-boost impulse rather than a destructive shock.
          </p>
        </div>

        <div class="muzzle-grid">

          <div class="muzzle-card seal-card">
            <div class="mc-label amber">PROPRIETARY SEAL DESIGN</div>
            <h4>Three-Layer Cryogenic Membrane System</h4>
            <div class="layer-stack">
              <div class="layer">
                <div class="layer-num">L3</div>
                <div class="layer-info">
                  <div class="layer-name">Structural Diaphragm (atmosphere side)</div>
                  <div class="layer-desc">Carbon fiber composite. Holds the {RAIL.pressureAtm} atm differential between
                  vacuum interior and ambient atmosphere. Scored for controlled radial fracture on vehicle contact.
                  Replaced per-launch.</div>
                </div>
              </div>
              <div class="layer">
                <div class="layer-num" style="color:var(--fg-dim)">L2</div>
                <div class="layer-info">
                  <div class="layer-name">Thermal Isolation Buffer</div>
                  <div class="layer-desc">Multi-layer aerogel insulation, ~25 cm thick. Thermally isolates the L1 LH₂ layer
                  from the L3 structural skin. Maintains LH₂ at {RAIL.muzzleLh2TempK} K against ambient heat soak between launches.</div>
                </div>
              </div>
              <div class="layer">
                <div class="layer-num" style="color:var(--amber)">L1</div>
                <div class="layer-info">
                  <div class="layer-name" style="color:var(--amber)">Liquid Hydrogen Membrane ({RAIL.muzzleLh2TempK} K)</div>
                  <div class="layer-desc">The proprietary layer. ~3 cm of LH₂ contained between cryogenic-rated thin films.
                  On vehicle breach, the LH₂ flashes to gas, vents into the atmospheric wake, mixes stoichiometrically with O₂,
                  and detonates from plasma-temperature ignition on the vehicle skin. Controlled detonation geometry directs
                  the impulse forward — adding ~50 m/s Δv at minimal vehicle mass cost.</div>
                </div>
              </div>
            </div>
            <div class="seal-stat">Seal replacement: per launch · Reset time: ~30 min (LH₂ refill) · Net thrust gain: ~50 m/s Δv</div>
          </div>

          <div class="muzzle-card nose-card">
            <div class="mc-label cyan">ADVANCED NOSE CONE DESIGN</div>
            <h4>Gryphon Nose — Type 2 (LH₂ Compatible)</h4>
            <p class="nose-intro">Vehicle nose architecture engineered for the LH₂ membrane breach event.
            Five concentric material layers, each solving a different physics problem in sequence:</p>
            <div class="nose-layers">
              <div class="nl">
                <div class="nl-mat" style="background:#e0e0e0;"></div>
                <div class="nl-info">
                  <div class="nl-name">Tungsten Carbide Tip (WC-Co sintered · 50 mm dia.)</div>
                  <div class="nl-fn">Penetrates the L3 structural diaphragm. Hardest manufactured engineering material.
                  Survives {RAIL.exitVelocityMs.toLocaleString()} m/s impact without deformation. Per-launch replaceable on threaded collar.</div>
                </div>
              </div>
              <div class="nl">
                <div class="nl-mat" style="background:#ccc8aa;"></div>
                <div class="nl-info">
                  <div class="nl-name">Silicon Carbide Ceramic Ogive (SiC · full nose shape)</div>
                  <div class="nl-fn">Survives the LH₂/O₂ detonation wave: peak temperature ~3,000 K for ~10 ms.
                  Provides aerodynamic nose form through Mach {RAIL.exitMach}→{GRYPHON.maxMach} atmospheric transit.
                  Ablates controlled layer of material, protecting the structure behind it.</div>
                </div>
              </div>
              <div class="nl">
                <div class="nl-mat" style="background:#1a1a1a;"></div>
                <div class="nl-info">
                  <div class="nl-name">Carbon-Carbon Composite Shell (C/C · 15 mm wall)</div>
                  <div class="nl-fn">Primary thermal protection for Mach {GRYPHON.maxMach} atmospheric ascent.
                  Rated to 1,650°C continuous. Active transpiration cooling integrated with vehicle LH₂ supply
                  (per Boyd hypersonics review). Maintains structural integrity through the full Gryphon trajectory.</div>
                </div>
              </div>
              <div class="nl">
                <div class="nl-mat" style="background:#8B7355;"></div>
                <div class="nl-info">
                  <div class="nl-name">Duocel Aluminum Foam Collar (6-8% density · 60 mm deep)</div>
                  <div class="nl-fn">Absorbs the membrane impact impulse and the detonation back-pressure transient
                  before it reaches the payload bay. Irreversibly crushes on severe impact, providing one-time energy absorption.
                  Inspected and replaced if deformed after each launch.</div>
                </div>
              </div>
              <div class="nl">
                <div class="nl-mat" style="background:#2255cc;"></div>
                <div class="nl-info">
                  <div class="nl-name">Ti-6Al-4V Shock Collar Ring (titanium alloy · structural)</div>
                  <div class="nl-fn">Final interface between nose and payload bay. Distributes all residual
                  impact load into the vehicle monocoque ring frame. Rated for &gt;{Math.round(RAIL.peakGForce * 25)} G nose-on transient loading.
                  Isolates payload bay from both the LH₂ detonation event and atmospheric entry shock.</div>
                </div>
              </div>
            </div>
            <div class="nose-perf">
              <div class="np"><span>Impact velocity</span><span class="cyan">{RAIL.exitVelocityMs.toLocaleString()} m/s (Mach {RAIL.exitMach})</span></div>
              <div class="np"><span>Detonation peak temp</span><span class="amber">~3,000 K · 10 ms</span></div>
              <div class="np"><span>Structural reuse</span><span class="lime">30+ launches (C/C shell)</span></div>
              <div class="np"><span>Tip replacement</span><span>Per-launch (WC-Co threaded)</span></div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── CARGO PODS ──────────────────────────────────────────── -->
  <section class="section" id="pods">
    <div class="container">
      <div class="section-header">
        <div class="label">Manna Cargo Pods</div>
        <h2>Unmanned Resupply System</h2>
        <p class="section-desc">
          Where Gryphon carries crew at 4G human-rated acceleration, Manna pods carry cargo at
          2.5G–108G — unlocking dramatically higher exit velocities, smaller propellant fractions,
          and per-kg costs that make sustained lunar operations economically viable.
          Three variants cover every cargo class. Four more are in design.
        </p>
      </div>
      <PodComparison client:only="svelte" />
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── PHYSICS / MATH ─────────────────────────────────────── -->
  <section class="section" id="math">
    <div class="container">
      <div class="section-header">
        <div class="label">Core Physics</div>
        <h2>The Numbers Behind the Architecture</h2>
      </div>
      <div class="math-grid">
        <div class="card math-card">
          <div class="math-label">Tsiolkovsky Rocket Equation</div>
          <div class="math-eq mono">Δv = Isp × g₀ × ln(m₀/m₁)</div>
          <p class="math-desc">By providing {RAIL.exitVelocityMs.toLocaleString()} m/s from ground-based magnets, BGKPJR delivers <strong>{(MISSION.railDvFraction * 100).toFixed(1)}%</strong> of the {MISSION.deltaVToLeoMs.toLocaleString()} m/s needed to reach LEO. Every m/s of rail Δv is a kg of propellant the vehicle no longer carries.</p>
        </div>
        <div class="card math-card">
          <div class="math-label">Rail Acceleration</div>
          <div class="math-eq mono">a = v² / (2L)</div>
          <p class="math-desc">For the {RAIL.lengthKm} km rail at Mach {RAIL.exitMach} exit: a = {RAIL.exitVelocityMs}² / (2 × {(RAIL.lengthKm*1000).toLocaleString()}) = <strong>{(RAIL.exitVelocityMs**2/(2*RAIL.lengthKm*1000)).toFixed(1)} m/s² ({(RAIL.exitVelocityMs**2/(2*RAIL.lengthKm*1000)/9.80665).toFixed(2)} G)</strong>. Sustained at {RAIL.peakGForce} G — within the 5 G patent envelope and well below the {(RAIL.peakGForce*1.25).toFixed(1)} G human limit.</p>
        </div>
        <div class="card math-card">
          <div class="math-label">Solar Sail Acceleration</div>
          <div class="math-eq mono">a = (2 × P_solar × A × η) / m</div>
          <p class="math-desc">At 1 AU, solar pressure = 4.56 × 10⁻⁶ Pa. With 1,200 m² sail and 3.2 kg mass, effective acceleration ≈ <strong>1.8 mm/s²</strong> — low but continuous. Over 6 months: Δv ≈ <strong>2.8 km/s</strong> with zero propellant.</p>
        </div>
        <div class="card math-card">
          <div class="math-label">Cost Reduction Model</div>
          <div class="math-eq mono">C_BGKPJR = C_prop × (1 − 0.40) + C_fixed / N</div>
          <p class="math-desc">Eliminating the first stage cuts propellant cost by 40%. Amortizing fixed costs over N = 50 launches/year achieves the $800/kg Phase 1 target. Serial production (N = 200/year) achieves <strong>$200/kg</strong> — a 96% reduction vs. Falcon 9.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ──────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-mark">⚡</span>
        <span>BGKPJR Architecture</span>
        <span class="footer-byline">Shane Brazelton + Claude (Anthropic) — Building for the left-behind user</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/thebardchat/BGKPJR-Core-Simulations" target="_blank" rel="noopener">Core Simulations</a>
        <a href="https://github.com/thebardchat/manna" target="_blank" rel="noopener">Manna Pods</a>
        <a href="https://github.com/thebardchat/manna-pods" target="_blank" rel="noopener">Manna Concepts</a>
        <a href="https://github.com/thebardchat/tug" target="_blank" rel="noopener">Orbital Tug</a>
        <a href="https://claude.ai/referral/4fAMYN9Ing" target="_blank" rel="noopener">Try Claude Free →</a>
      </div>
      <div class="footer-legal mono">Pre-Phase A concept. All physics values are calculated estimates — not peer-reviewed engineering data. Apache 2.0.</div>
    </div>
  </footer>
</Layout>

<style>
/* ── header ── */
.site-header { border-bottom: 1px solid #192e4c; background: rgba(4,9,16,.95); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 100; }
.header-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 16px; flex-wrap: wrap; gap: 12px; }
.logo { display: flex; align-items: center; gap: 10px; }
.logo-mark { font-size: 22px; }
.logo-text { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: 18px; color: #00e5ff; }
.logo-sub { font-family: "JetBrains Mono", monospace; font-size: 11px; color: #4d6680; }
.nav { display: flex; gap: 24px; }
.nav a { font-size: 13px; color: #8faec8; transition: color .15s; font-weight: 500; }
.nav a:hover { color: #00e5ff; text-decoration: none; }

/* ── hero ── */
.hero { padding-block: 100px 80px; border-bottom: 1px solid #192e4c; }
.hero-inner { display: flex; flex-direction: column; align-items: flex-start; gap: 28px; }
.hero-eyebrow { display: flex; gap: 10px; flex-wrap: wrap; }
.hero-title { font-size: clamp(32px, 6vw, 72px); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; }
.accent-text { color: #00e5ff; }
.hero-desc { font-size: 17px; color: #8faec8; max-width: 640px; line-height: 1.7; }
.hero-stats { display: flex; align-items: center; gap: 0; flex-wrap: wrap; margin-top: 12px; }
.stat { padding: 0 28px; }
.stat:first-child { padding-left: 0; }
.stat-val { font-family: "Space Grotesk", sans-serif; font-size: 26px; font-weight: 700; color: #00e5ff; }
.stat-label { font-family: "JetBrains Mono", monospace; font-size: 10px; color: #4d6680; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 2px; }
.stat-div { width: 1px; height: 40px; background: #192e4c; }

/* ── section header ── */
.section-header { margin-bottom: 40px; }
.section-header h2 { font-size: clamp(24px, 4vw, 40px); margin-top: 8px; }
