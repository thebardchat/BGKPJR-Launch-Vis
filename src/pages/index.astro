---
import Layout from "../layouts/Layout.astro";
import LaunchVisualizer from "../islands/LaunchVisualizer.svelte";
import PodComparison from "../islands/PodComparison.svelte";
import TubeCrossSection from "../islands/TubeCrossSection.svelte";
import { RAIL, GRYPHON, KEPLER, COSTS, MISSION, SPACE_TUG, TIMELINE, SPACE_PIPELINE, MUZZLE_ALTERNATIVES } from "../data/launch";
---
<Layout>
  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo">
        <span class="logo-mark">⚡</span>
        <span class="logo-text">BGKPJR</span>
        <span class="logo-sub">Launch Architecture</span>
      </div>
      <nav class="nav">
        <a href="#pipeline">Pipeline</a>
        <a href="#timeline">Timeline</a>
        <a href="#systems">Stages</a>
        <a href="#tube">Tube</a>
        <a href="#pods">Pods</a>
        <a href="#audit">Status</a>
        <a href="https://github.com/thebardchat/BGKPJR-Core-Simulations" target="_blank" rel="noopener">Sims →</a>
      </nav>
    </div>
  </header>

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero blueprint-grid">
    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <span class="badge badge-cyan">Pre-Phase A Concept</span>
        <span class="badge badge-amber">EM Launch Architecture</span>
        <span class="badge badge-lime">90% Cost Reduction Target</span>
      </div>
      <h1 class="hero-title">
        Brazelton Gryphon Kepler<br/>
        <span class="accent-text">Propulsion Jump Revolution</span>
      </h1>
      <p class="hero-desc">
        <strong style="color:#00e5ff">The missing link in the Space Pipeline.</strong>
        Blue Origin and SpaceX are building the lunar landers. NASA is flying Artemis crews every {TIMELINE.artemisCadenceMonths} months.
        Nobody yet has a way to get cargo into low Earth orbit cheaply enough to feed a permanent moon base.
        BGKPJR is a {RAIL.lengthKm}-km evacuated coilgun tunnel that accelerates unmanned cargo pods to Mach {RAIL.exitMach}
        ({RAIL.exitVelocityMs.toLocaleString()} m/s) on ground-based magnets — no first-stage propellant, no booster to recover.
        Operational cargo pipeline in {TIMELINE.operationalCargoYearLow - TIMELINE.programStartYear}–{TIMELINE.operationalCargoYearHigh - TIMELINE.programStartYear} years.
      </p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-val">{RAIL.lengthKm} km</div>
          <div class="stat-label">Maglev Rail</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">Mach {RAIL.exitMach}</div>
          <div class="stat-label">Exit Velocity</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">{KEPLER.sailAreaM2.toLocaleString()} m²</div>
          <div class="stat-label">Kepler Sail</div>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <div class="stat-val">${COSTS.bgkpjrMaturePerKg}/kg</div>
          <div class="stat-label">Target Cost</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── LAUNCH VISUALIZER ─────────────────────────────────────── -->
  <section class="section" id="visualizer">
    <div class="container">
      <div class="section-header">
        <div class="label">Interactive Simulation</div>
        <h2>Full Mission Sequence</h2>
        <p class="section-desc">
          Watch all four stages in real-time: maglev acceleration, Gryphon wing deploy and atmospheric
          climb, hybrid propulsion burn to orbit, and Kepler solar sail deployment. Use the controls
          to scrub through mission time or jump to any stage.
        </p>
      </div>
      <LaunchVisualizer client:only="svelte" />
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── SPACE PIPELINE ───────────────────────────────────────── -->
  <section class="section" id="pipeline">
    <div class="container">
      <div class="section-header">
        <div class="label">The Big Picture</div>
        <h2>The Space Pipeline</h2>
        <p class="section-desc">{SPACE_PIPELINE.thesis}</p>
      </div>
      <div class="pipeline-grid">
        {SPACE_PIPELINE.stages.map((s) => (
          <div class="pipeline-card">
            <div class="pl-num">0{s.stage}</div>
            <div class="pl-actor">{s.actor}</div>
            <div class="pl-action">{s.action}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── MANHATTAN TIMELINE ───────────────────────────────────── -->
  <section class="section" id="timeline">
    <div class="container">
      <div class="section-header">
        <div class="label">The Manhattan Timeline</div>
        <h2>Operational Cargo Pipeline in {TIMELINE.operationalCargoYearLow - TIMELINE.programStartYear}–{TIMELINE.operationalCargoYearHigh - TIMELINE.programStartYear} Years</h2>
        <p class="section-desc">
          Assuming a {TIMELINE.programStartYear} program start, an operational unmanned cargo pipeline can be in service by
          {TIMELINE.operationalCargoYearLow}–{TIMELINE.operationalCargoYearHigh}. Parallel to NASA Artemis crew launches every
          {TIMELINE.artemisCadenceMonths} months using SpaceX HLS or Blue Moon Mk2 landers. Lunar base target: {TIMELINE.lunarBaseTargetYear}.
          Every Artemis crew that arrives finds a base already supplied by BGKPJR cargo.
        </p>
      </div>
      <div class="timeline-grid">
        {TIMELINE.phases.map((p) => (
          <div class={`timeline-card ${p.status === "ACTIVE" ? "active" : p.status === "PRIMARY OBJECTIVE" ? "primary" : "deferred"}`}>
            <div class="tl-phase">{p.phase}</div>
            <div class="tl-years">{p.years}</div>
            <div class="tl-name">{p.name}</div>
            <div class={`tl-status ${p.status === "ACTIVE" ? "lime" : p.status === "PRIMARY OBJECTIVE" ? "cyan" : "muted"}`}>{p.status}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── ARCHITECTURE STAGES ──────────────────────────────────── -->
  <section class="section" id="systems">
    <div class="container">
      <div class="section-header">
        <div class="label">Architecture Stages</div>
        <h2>Earth → LEO → Moon</h2>
        <p class="section-desc">
          Phase 1 critical path: cargo pods only. The crewed Gryphon vehicle is deferred to Phase 2 — same {RAIL.lengthKm} km rail accommodates both,
          but the unmanned cargo pipeline ships first.
        </p>
      </div>
      <div class="stages-grid">

        <div class="stage-card">
          <div class="stage-num cyan">01</div>
          <h3>Maglev Rail — "The Jump"</h3>
          <p>A {RAIL.lengthKm}-km evacuated coilgun tube at {RAIL.inclinationDeg}° incline accelerates the cargo pod to Mach {RAIL.exitMach} in {RAIL.runTimeSec} seconds. Tube pressure {RAIL.pressureAtm} atm. Linear synchronous motor architecture: copper drive coils on the rail, REBCO superconducting armature on the vehicle (cooled to {RAIL.armatureTempK} K). Peak field {RAIL.magFieldT} T. Sustained at {RAIL.peakGForce} G.</p>
          <table class="stage-table">
            <tr><td>Rail length</td><td class="cyan">{RAIL.lengthKm} km</td></tr>
            <tr><td>Exit velocity</td><td class="cyan">Mach {RAIL.exitMach} ({RAIL.exitVelocityMs.toLocaleString()} m/s)</td></tr>
            <tr><td>Peak G-load</td><td class="cyan">{RAIL.peakGForce} G</td></tr>
            <tr><td>Tube pressure</td><td class="cyan">{RAIL.pressureAtm} atm</td></tr>
            <tr><td>Drive architecture</td><td class="cyan">LSM coilgun · {RAIL.coilCount.toLocaleString()} coils @ {RAIL.coilSpacingM} m</td></tr>
            <tr><td>Magnet field</td><td class="cyan">{RAIL.magFieldT} T (REBCO armature @ {RAIL.armatureTempK} K)</td></tr>
            <tr><td>Muzzle seal</td><td class="cyan">LH₂ + thermite (trade study)</td></tr>
          </table>
          <a class="stage-deep-link" href="https://thebardchat.github.io/BGKPJR-Stage1-Tube" target="_blank" rel="noopener">Stage 1 Deep Dive →</a>
        </div>

        <div class="stage-card primary-card">
          <div class="stage-num amber">02</div>
          <h3>Manna Pods + Space Tug — "The Highway"</h3>
          <p>
            Pods exit the rail at Mach {RAIL.exitMach}, fire a small 2nd-stage rocket to push apogee to ~166 km (sub-orbital).
            A permanent in-space <strong style="color:#ffaa00">{SPACE_TUG.name}</strong>
            ({SPACE_TUG.sizeAnalogy.split('—')[0].trim()}) catches the pod at apogee, circularizes it to LEO with a {(SPACE_TUG.catchAndCircularizeMs/1000).toFixed(2)} km/s burn,
            refuels from a co-orbiting Manna-F propellant pod, then performs trans-lunar injection. The Tug hands off to a Blue Moon Mk2 or SpaceX HLS lander in lunar orbit.
            The Tug never lands and never fights Earth's gravity — it lives in space, refuels in space, and works in space.
          </p>
          <table class="stage-table">
            <tr><td>Tug dry mass</td><td class="amber">{SPACE_TUG.dryMassKg.toLocaleString()} kg</td></tr>
            <tr><td>Propellant capacity</td><td class="amber">{SPACE_TUG.propellantKg.toLocaleString()} kg per refuel</td></tr>
            <tr><td>Catch + circularize Δv</td><td class="amber">{(SPACE_TUG.catchAndCircularizeMs/1000).toFixed(2)} km/s (largest burn)</td></tr>
            <tr><td>TLI Δv (after refuel)</td><td class="amber">{(SPACE_TUG.cislunarTliMs/1000).toFixed(2)} km/s</td></tr>
            <tr><td>Total outbound Δv</td><td class="amber">{(SPACE_TUG.totalOutboundDvMs/1000).toFixed(1)} km/s (LEO refuel required)</td></tr>
            <tr><td>Refuel interface</td><td class="amber">Manna-F pods · long-term ISRU water</td></tr>
            <tr><td>Lifetime</td><td class="amber">{SPACE_TUG.lifetimeCycles} cycles (refurbishable)</td></tr>
          </table>
        </div>

        <div class="stage-card primary-card">
          <div class="stage-num lime">03</div>
          <h3>Lunar Surface — "The Base"</h3>
          <p>
            Lander delivers pods to the surface. Cargo offloaded by crane. <strong style="color:#b4ff6e">Empty pods don't get wasted</strong> — they become "Space LEGOs."
            NASA in-situ resource utilization research is designing ways to fill empty pressure vessels with lunar regolith,
            converting them into radiation-proof walls, storage sheds, and roads. <strong>Every pod we ship is a free building block for the first permanent moon city.</strong>
          </p>
          <table class="stage-table">
            <tr><td>Pod end-of-life</td><td class="lime">Regolith-filled structure</td></tr>
            <tr><td>Lunar lander partner</td><td class="lime">Blue Moon Mk2 · SpaceX HLS</td></tr>
            <tr><td>Refuel source (long-term)</td><td class="lime">ISRU lunar water</td></tr>
            <tr><td>Crew arrival cadence</td><td class="lime">Artemis · every {TIMELINE.artemisCadenceMonths} mo</td></tr>
            <tr><td>Cargo cadence (initial)</td><td class="lime">{TIMELINE.bgkpjrCargoCadenceTargetInitial} pods / year</td></tr>
            <tr><td>Cargo cadence (mature)</td><td class="lime">{TIMELINE.bgkpjrCargoCadenceTargetMature} pods / year</td></tr>
          </table>
        </div>

      </div>
    </div>
  </section>

  <div class="divider container"></div>

  <!-- ── DEFERRED: GRYPHON + KEPLER ───────────────────────────── -->
  <section class="section" id="deferred">
    <div class="container">
      <div class="section-header">
        <div class="label" style="color:#4d6680">Phase 2 — Deferred</div>
        <h2 style="color:#8faec8">Future Vehicles: Gryphon &amp; Kepler</h2>
        <p class="section-desc">
          The crewed Gryphon waverider and the Kepler solar sail are technically valid concepts within the same {RAIL.lengthKm} km rail
          architecture, but they are <strong>deferred</strong> until the unmanned cargo pipeline is operational. Constants retained for
          forward-compatibility — the rail accommodates both vehicles. Showcase only; not on Phase 1 critical path.
        </p>
      </div>
      <div class="stages-grid">

        <div class="stage-card deferred-card">
          <div class="stage-num amber" style="opacity:0.5">02-DEFERRED</div>
          <h3 style="color:#8faec8">Gryphon — Atmospheric Ascent <span class="deferred-tag">DEFERRED</span></h3>
          <p>Hypersonic waverider with variable-geometry wings. At tube exit, wings deploy instantly. Aerodynamic lift to Mach {GRYPHON.maxMach},
          then hybrid propulsion to LEO. Glides back unpowered — no recovery propellant. Same rail as cargo pods.</p>
          <table class="stage-table">
            <tr><td>Wingspan</td><td class="amber">{GRYPHON.spanDeployedM} m deployed</td></tr>
            <tr><td>Dry mass</td><td class="amber">{(GRYPHON.massDryKg/1000).toFixed(0)} t (provisional)</td></tr>
            <tr><td>Payload</td><td class="amber">{GRYPHON.payloadKg.toLocaleString()} kg</td></tr>
            <tr><td>Max Mach</td><td class="amber">Mach {GRYPHON.maxMach}</td></tr>
            <tr><td>Glide ratio</td><td class="amber">{GRYPHON.glideRatio}:1</td></tr>
          </table>
        </div>

        <div class="stage-card deferred-card">
          <div class="stage-num lime" style="opacity:0.5">03-DEFERRED</div>
          <h3 style="color:#8faec8">Kepler Sail — Deep-Space Δv <span class="deferred-tag">DEFERRED</span></h3>
          <p>Above {KEPLER.deployAltKm} km, a {KEPLER.sailAreaM2.toLocaleString()} m² {KEPLER.materialCP1} solar sail deploys.
          Zero propellant; solar pressure at 1 AU gives {KEPLER.nominalDvMmps} mm/s² continuous Δv. For Phase 4 deep-space
          missions only — no role in cargo-to-Moon pipeline.</p>
          <table class="stage-table">
            <tr><td>Sail area</td><td class="lime">{KEPLER.sailAreaM2.toLocaleString()} m²</td></tr>
            <tr><td>Sail mass</td><td class="lime">{KEPLER.massKg} kg</td></tr>
            <tr><td>Material</td><td class="lime">{KEPLER.materialCP1}</td></tr>
            <tr><td>Deploy altitude</td><td class="lime">{KEPLER.deployAltKm} km</td></tr>
            <tr><td>Solar ΔV</td><td class="lime">{KEPLER.nominalDvMmps} mm/s²</td></tr>
          </table>
        </div>

      </div>
    </div>
  </section>


  <div class="divider container"></div>

  <!-- ── INSIDE THE LAUNCH TUBE ───────────────────────────────── -->
  <section class="section" id="tube">
    <div class="container">
      <div class="section-header">
        <div class="label">Stage 1 — Deep Dive</div>
        <h2>Inside the EM Launch Tube</h2>
        <p class="section-desc">
          The {RAIL.lengthKm} km barrel is the largest electromagnetic accelerator ever proposed.
          {RAIL.coilCount.toLocaleString()} copper drive coils at {RAIL.coilSpacingM} m spacing form a Linear Synchronous Motor:
          stationary coils on the tube, REBCO superconducting armature on the vehicle. The pod surfs a traveling
          magnetic wave from zero to Mach {RAIL.exitMach} in {RAIL.runTimeSec} seconds — then breaches a liquid-hydrogen
          cryogenic membrane that holds the vacuum behind it. The membrane breach is the engineered event
          that gates the entire architecture.
        </p>
      </div>

      <TubeCrossSection client:only="svelte" />

      <div class="tube-mech-grid">
        <div class="tube-card">
          <div class="tc-num">01</div>
          <h4>Sequential Coil Firing</h4>
          <p>Each copper drive coil along the {RAIL.lengthKm} km tube is energized individually, timed to the pod&apos;s exact position.
          Leading coils fire first, generating forward magnetic attraction. Trailing coils de-energize immediately
          to prevent back-pull. The result is a traveling magnetic wave that the vehicle&apos;s onboard REBCO armature
          continuously chases — Linear Synchronous Motor architecture, identical in principle to a maglev train scaled to launch energies.</p>
          <div class="tc-spec">{RAIL.coilCount.toLocaleString()} coils · {RAIL.coilSpacingM} m spacing · &lt;1 ms switching · {RAIL.magFieldT} T peak field</div>
        </div>
        <div class="tube-card">
          <div class="tc-num">02</div>
          <h4>The Vehicle Armature</h4>
          <p>The midsection of the vehicle carries a REBCO high-temperature superconducting armature ring,
          chilled to {RAIL.armatureTempK} K by an onboard cryostat that doubles as the LH₂ propellant tank.
          The armature couples magnetically to the tube&apos;s traveling field. No physical contact with the bore wall.
          No friction. No rail erosion. The vehicle rides a magnetic cushion at {RAIL.peakGForce} G for {RAIL.runTimeSec} seconds.</p>
          <div class="tc-spec">REBCO armature · {RAIL.armatureTempK} K LH₂ coolant · ~30 mm bore clearance</div>
        </div>
        <div class="tube-card">
          <div class="tc-num">03</div>
          <h4>{RAIL.energyGJ} GJ Energy Source</h4>
          <p>A single launch transfers ~{Math.round(0.5 * GRYPHON.massGrossFuelKg * RAIL.exitVelocityMs ** 2 / 1e9)} GJ of kinetic energy
          to a fully-loaded vehicle (mass {(GRYPHON.massGrossFuelKg/1000).toFixed(0)} t at {RAIL.exitVelocityMs.toLocaleString()} m/s).
          With drive efficiency ~60%, the SMES (Superconducting Magnetic Energy Storage) bank stores {RAIL.energyGJ} GJ.
          Peak discharge lasts {RAIL.runTimeSec} seconds. Charge rate: {RAIL.chargeRateMW} MW. Peak draw: {RAIL.peakPowerGW} GW.
          Rail Δv represents {(MISSION.railDvFraction * 100).toFixed(0)}% of the {MISSION.deltaVToLeoMs.toLocaleString()} m/s required to reach LEO — the rest is rocket propulsion.</p>
          <div class="tc-spec">Stored energy: {RAIL.energyGJ} GJ · Peak power: {RAIL.peakPowerGW} GW · Recharge: {RAIL.chargeTimeMin} min</div>
        </div>
      </div>

      <!-- ══ MUZZLE INTERFACE — DUAL ALTERNATIVES (TRADE STUDY) ══ -->
      <div class="muzzle-section">
        <div class="muzzle-header">
          <div class="label" style="color:var(--amber)">The Critical Engineering Problem · Open Trade Study</div>
          <h3>The Muzzle Interface — Two Alternative Architectures</h3>
          <p>
            When a vehicle exits the tube at Mach {RAIL.exitMach} ({RAIL.exitVelocityMs.toLocaleString()} m/s), it transitions
            from {RAIL.pressureAtm} atm vacuum into ~1 atm atmosphere in milliseconds.
            Dynamic pressure at exit is {RAIL.muzzleStagnationMPa} MPa — without mitigation, the structural shock destroys the vehicle.
            The membrane that holds the tube vacuum, and how the vehicle breaches it, is the single most-load-bearing engineering decision in the architecture.
          </p>
          <p style="margin-top:14px">
            <strong style="color:#ddeeff">Two parallel alternatives are under study.</strong> A formal trade study in Phase 0 will determine the
            canonical choice. We document both honestly here:
          </p>
        </div>

        <div class="muzzle-alts-grid">
          <div class="muzzle-alt lh2">
            <div class="ma-header">
              <div class="ma-name" style="color:#00e5ff">{MUZZLE_ALTERNATIVES.lh2.name}</div>
              <div class="ma-badge canon">CURRENT CANONICAL</div>
            </div>
            <p style="font-size:13px;color:#8faec8;line-height:1.65">
              A thin {MUZZLE_ALTERNATIVES.lh2.membraneTempK} K liquid-hydrogen membrane sealed behind a structural diaphragm. As the vehicle breaches it,
              the LH₂ vaporizes (~1000× volume expansion), mixes with atmospheric oxygen in the wake, and detonates. The detonation wave is
              engineered to propagate <em>behind</em> the vehicle, providing a ~{MUZZLE_ALTERNATIVES.lh2.thrustBoostMs} m/s thrust impulse rather than a destructive shock.
            </p>
            <div class="ma-h">ADVANTAGES</div>
            <ul class="ma-list pro">
              {MUZZLE_ALTERNATIVES.lh2.advantages.map((a) => <li>{a}</li>)}
            </ul>
            <div class="ma-h">DISADVANTAGES</div>
            <ul class="ma-list con">
              {MUZZLE_ALTERNATIVES.lh2.disadvantages.map((d) => <li>{d}</li>)}
            </ul>
            <div class="seal-stat">Reset time: ~{MUZZLE_ALTERNATIVES.lh2.resetTimeMin} min · Net Δv gain: ~{MUZZLE_ALTERNATIVES.lh2.thrustBoostMs} m/s · Novel IP: yes</div>
          </div>

          <div class="muzzle-alt thermite">
            <div class="ma-header">
              <div class="ma-name" style="color:#ffaa00">{MUZZLE_ALTERNATIVES.thermite.name}</div>
              <div class="ma-badge alt">ALTERNATIVE</div>
            </div>
            <p style="font-size:13px;color:#8faec8;line-height:1.65">
              A three-layer membrane: structural carbon-fiber diaphragm + aerogel buffer + L1 thermite (Al/Fe₂O₃). On tungsten-carbide tip contact at
              {MUZZLE_ALTERNATIVES.thermite.ignitionVelocityMs.toLocaleString()} m/s, friction initiates thermite combustion across the membrane in
              &lt;{MUZZLE_ALTERNATIVES.thermite.ignitionTimeUs} μs. The membrane self-consumes into alumina dust and iron vapor — zero solid debris field.
              The vehicle passes through a brief plasma aperture rather than a solid barrier. {MUZZLE_ALTERNATIVES.thermite.peakTempC.toLocaleString()} °C peak.
            </p>
            <div class="ma-h">ADVANTAGES</div>
            <ul class="ma-list pro">
              {MUZZLE_ALTERNATIVES.thermite.advantages.map((a) => <li>{a}</li>)}
            </ul>
            <div class="ma-h">DISADVANTAGES</div>
            <ul class="ma-list con">
              {MUZZLE_ALTERNATIVES.thermite.disadvantages.map((d) => <li>{d}</li>)}
            </ul>
            <div class="seal-stat">Reset time: ~{MUZZLE_ALTERNATIVES.thermite.resetTimeMin} min · Per-launch consumable: ~$2,400 · Novel IP: no</div>
          </div>
        </div>

        <div style="margin-top:24px;padding:18px 22px;border-radius:10px;background:rgba(0,229,255,0.04);border:1px dashed #192e4c">
          <div class="label" style="color:#00e5ff">Trade study deliverables (Phase 0)</div>
          <ul style="font-size:13px;color:#8faec8;line-height:1.7;margin-top:10px;padding-left:18px">
            <li>Detonation control modeling for LH₂ alternative — central feasibility risk</li>
            <li>Subscale demonstration of both alternatives at representative pressures and velocities</li>
            <li>Per-launch cost comparison including infrastructure amortization</li>
            <li>Failure-mode analysis (FMEA) for both</li>
            <li>Alignment with vehicle nose architecture (Type-1 thermite-compatible vs Type-2 LH₂-compatible)</li>
          </ul>
        </div>
      </div>

      <!-- ══ ORIGINAL DETAILED MUZZLE BREAKDOWN BELOW ══ -->
      <div class="muzzle-section" style="margin-top:32px">
        <div class="muzzle-header">
          <div class="label" style="color:var(--amber)">Detailed Implementation Specifications · LH₂ Canonical</div>
          <h3 style="font-size:24px">Reference Implementation: LH₂ Membrane + Type-2 Nose</h3>
          <p>Detailed layer-by-layer specification for the current canonical (LH₂) muzzle architecture.</p>
        </div>

        <div class="muzzle-grid">

          <div class="muzzle-card seal-card">
            <div class="mc-label amber">PROPRIETARY SEAL DESIGN</div>
            <h4>Three-Layer Cryogenic Membrane System</h4>
            <div class="layer-stack">
              <div class="layer">
                <div class="layer-num">L3</div>
                <div class="layer-info">
                  <div class="layer-name">Structural Diaphragm (atmosphere side)</div>
                  <div class="layer-desc">Carbon fiber composite. Holds the {RAIL.pressureAtm} atm differential between
                  vacuum interior and ambient atmosphere. Scored for controlled radial fracture on vehicle contact.
                  Replaced per-launch.</div>
                </div>
              </div>
              <div class="layer">
                <div class="layer-num" style="color:var(--fg-dim)">L2</div>
                <div class="layer-info">
                  <div class="layer-name">Thermal Isolation Buffer</div>
                  <div class="layer-desc">Multi-layer aerogel insulation, ~25 cm thick. Thermally isolates the L1 LH₂ layer
                  from the L3 structural skin. Maintains LH₂ at {RAIL.muzzleLh2TempK} K against ambient heat soak between launches.</div>
                </div>
              </div>
